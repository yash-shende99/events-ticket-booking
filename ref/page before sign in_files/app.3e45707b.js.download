:"Physical",value:"N"}],l="Keep your original PAN card handy for the session",d="https://webassets.rbl.bank.in/document/Credit%20Cards/RBL-MITC-final.pdf",p="https://webassets.rbl.bank.in/document/pdfs/credit-card-member-declaration.pdf",m="https://webassets.rbl.bank.in/document/credit-cards/rbl-cc-cardmember-agreement.pdf",u="https://webassets.rbl.bank.in/document/credit-cards/kfs-500.pdf",y="https://webassets.rbl.bank.in/document/credit-cards/play-credit-card-terms-and-conditions.pdf",g="https://webassets.rbl.bank.in/document/Credit%20Cards/CardsScheduleCharges.pdf",h=[{id:1,data:[{id:1,text:"I don't have tax liability outside India."}]},{id:2,data:[{id:1,text:"I have read and understood the "},{id:2,text:"Card Member Declaration, ",link:p},{id:3,text:"Key Fact Statement, ",link:u},{id:4,text:"Card Member Agreement, ",link:m},{id:5,text:"Terms and Conditions, ",link:d},{id:6,text:"Product T&C, ",link:y},{id:7,text:"SOC ",link:g},{id:8,text:"and agree with the same."}]},{id:3,data:[{id:1,text:"I authorize RBL Bank to capture name and information in the application as per PAN/PANSITE or Aadhaar (eKYC/offline KYC/Biometric KYC) for KYC compliance purpose."}]},{id:4,data:[{id:1,text:"I will not share any details related to my Credit Card like Card number,  CVV, Expiry, PIN and OTP with anyone."}]}],f=[{text:"Disclaimer: To select a network of your choice, do reach out to RBL Bank Credit Card helpline at +91 22 6232 7777"}],E={consent:"I Consent / ",dontConsent:"I Dissent, ",tnc:"to sharing of my personal information (including details disclosed in this application form) by the Bank, without any further consent or authorisation from me to its Group Companies/Subsidiaries/Affiliates/Service providers for the purpose of marketing & promotional offers offered by the Bank through calls, sms, email or any other mode."},v=["1. You will recieve an SMS confirmation along with the link to join the video call","2. A RBL bank officer will direct you through the KYC process","3. M