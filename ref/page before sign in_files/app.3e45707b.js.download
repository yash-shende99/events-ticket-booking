="Gender",fi="Net Monthly Income Range",Ei="Address Line 1",vi="Address Line 2",_i="Address Line 1 & 2",Ti="Area Pincode",bi="Loading Town/City",Si="Town/City",Ci="Loading State",Ai="State",Ii="Father’s full name",xi="Mother’s full name",Ri="Are you married?",Oi="Your occupation",ki="Employer type",wi="Office Area Pincode",Li="Office Name",Di="Office Address",Ni="Deliver card to",ji="Delivery statement",Pi="Cannot edit. You are required to use your BookMyShow registered number only",Mi="Application processing is subject to successful email ID verification",Bi="Your pan is already verified.",Ui="customerName",Fi="First Name",Gi="Middle Name",Hi="Last Name",Yi="pan",Vi="dob",Wi="email",Ki="phone",$i="nmi",Qi="gender",qi="line1",zi="line2",Xi="pin",Zi="city",Ji="state",ea="fathersName",ta="mothersName",oa="maritalStatus",sa="employmentType",na="empType",ia="companyType",aa="pinCode",ra="employerName",ca="employerAddress1",la="employerCity",da="employerState",pa="cardDeliverAddress",ma="goGreenFlag",ua="crossSellingConsent",ya="Something went wrong. Please try again later.",ga="M",ha="MARRIED",fa="RESIDENCE",Ea="Not received the OTP? Resend",va="Recommended",_a=`${n.BMSCDN_ASSETS_URL}/static/2022/05/instant-offer.png`,Ta="16px",ba="16px",Sa=/^[a-zA-Z0-9\s]{2,40}$/,Ca=/^[a-zA-Z0-9, \-.#/]{3,80}$/,Aa=/^[a-zA-Z0-9, \-.#_/]{4,40}$/,Ia=/^(?=.*\d)(?=.*[a-zA-Z]).*$/,xa=/^(?!.*[@!$%^&*()<>?|}{~:]).{3,50}$/,Ra=/^(?!\b(FATHER|MOTHER)\b(?!\s+\S))(?!.*\b(NIL|NULL)\b.*).*$/i,Oa=/^(?!.*\b(Mr|mr|MR|Mrs|mrs|MRS|MRs)\b).+$/,ka=[{label:"Income Range",value:""},{label:"₹0 - ₹25,000",value:12500},{label:"₹25,001 - ₹50,000",value:35e3},{label:"₹50,001 - ₹75,000",value:62500},{label:"₹75,001 - ₹1,00,000",value:87500},{label:"₹1,00,000+",value:1e5}],wa=[{id:1,recommended:!0,recommendedText:"Recommended",title:"Video KYC",description:"Proceed for Video KYC with your Aadhaar Card",banner:`${n.BMSCDN_ASSETS_URL}/static/2022/05/vkyc-mode.png`,imageWidth:"106px",imageHeight:"92px",ctaText:"Proceed",notificationImage:`${n.BMSCDN_ASSETS_URL}/static/2022/05/instant-offer.png`,notificationImageWidth:"16px",notificationImageHeight:"16px",notification:"Earn ₹200 BMS cash on card approval through video KYC",isVkyc:!0,isNotificationAvailable:!0},{id:2,recommended:!1,title:"In-person KYC",description:"A RBL bank officer will visit you In-person to complete biometric KYC.  ",banner:`${n.BMSCDN_ASSETS_URL}/static/2022/05/biometric-mode.png`,imageWidth:"118px",imageHeight:"75px",ctaText:"Proceed",isVkyc:!1,isNotificationAvailable:!1}],La={tabSection:{fileName:"play-credit-card",offerSectionSvgName:"offer-tab",offerSectionSvgHeight:"28",offerSectionSvgWidth:"28",offerSectionText:"Offers & Benefits",playCardSectionSvgName:"play-card-tab",playCardSectionSvgHeight:"28",playCardSectionSvgWidth:"28",playCardSectionText:"My Play Card"},inactiveCardSection:{fileName:"play-credit-card",applicationStartedText:"Application started on",monthlyCreditLimitText:"Monthly credit limit",playLogoSVGName:"play",playLogoSVGWidth:"68",playLogoSVGHeight:"32",wifiLogoImage:`${n.BMSCDN_ASSETS_URL}/webin/static/wifiCard.png`,visaLogoImage:`${n.BMSCDN_ASSETS_URL}/static/2022/05/visa-card.png`,masterLogoImage:`${n.BMSCDN_ASSETS_URL}/webin/static/masterCard.png`,visaLogoAltTag:"Visa Logo",wifiLogoAltTag:"image",masterLogoAltTag:"Master Logo",visaLogoImageWidth:"50",visaLogoImageHeight:"40",masterLogoImageWidth:"70",masterLogoImageHeight:"70",inCompleteApplicationWithoutCreditLimit:{helperText:"Complete your application to start the process",ctaText:"Complete Application",goToOffers:!1,analyticsLabel:"complete_application"},inCompleteApplicationWithCreditLimit:{helperText:"Please complete your application to start the process",ctaText:"Continue application",goToOffers:!1,analyticsLabel:"complete_application"},applicationSubmittedKycPending:{helperText:"Check out offers on Play until your application is under review",ctaText:"Continue application",goToOffers:!1,analyticsLabel:"complete_application"},applicationSubmittedKycCompleted:{helperText:"Check out offers on Play until your card is on its way",ctaText:"Go to offers",goToOffers:!0,analyticsLabel:"go_to_offers"},inActiveCard:{helperText:"Check out offers on Play until your card is on its way",ctaText:"Go to offers",goToOffers:!0,analyticsLabel:"go_to_offers"},inActiveUkycCard:{helperText:"Check out offers on Play until your application is under review",ctaText:"Continue application",goToOffers:!1,analyticsLabel:"complete_application"}},cardMenuSection:[{id:1,imageURL:`${n.BMSCDN_ASSETS_URL}/static/2022/05/view-my-statements.png`,imageWidth:"18",imageHeight:"18",Title:"View card statements",url:s.PLAY_CREDIT_CARD_STATEMENTS,analyticsLabel:"view_card_statement"},{id:2,imageURL:`${n.BMSCDN_ASSETS_URL}/static/2022/05/debit-card.png`,imageWidth:"21",imageHeight:"20",Title:"Manage my card",url:s.PLAY_CREDIT_CARD_MANAGE_MY_CARD,analyticsLabel:"manage_my_card"},{id:3,imageURL:`${n.BMSCDN_ASSETS_URL}/static/2022/05/customer-support.png`,imageWidth:"16",imageHeight:"16",Title:"Customer Support",url:s.PLAY_CREDIT_CARD_CUSTOMER_SUPPORT,analyticsLabel:"contact_support"}],activeCardSection:{fileName:"play-credit-card",cardHolderNameText:"Card Holder Name",dueDateText:"Due date",totalOutstandingText:"Total outstanding",availableLimitText:"Total credit limit",paymentDueInText:"Payment due in",noDuesText:"To view your card details",payNowText:"Click Here",payNowImage:`${n.BMSCDN_ASSETS_URL}/static/2022/05/pay-now.png`,payNowImageWidth:"21",payNowImageHeight:"16",playLogoSVGName:"play",playLogoSVGWidth:"68",playLogoSVGHeight:"32",wifiLogoImage:`${n.BMSCDN_ASSETS_URL}/webin/static/wifiCard.png`,visaLogoImage:`${n.BMSCDN_ASSETS_URL}/static/2022/05/visa-card.png`,masterLogoImage:`${n.BMSCDN_ASSETS_URL}/webin/static/masterCard.png`,wifiLogoAltTag:"image",visaLogoAltTag:"Visa Logo",masterLogoAltTag:"Master Logo",visaLogoImageWidth:"50",visaLogoImageHeight:"40",masterLogoImageWidth:"70",masterLogoImageHeight:"70"},monthlyOffer:{headline:"Treat yo’ self!",subHeadline:"Get exciting monthly offers. Read more on how to avail",monthlyOffers:[{code:1,heading:"Get ₹100 off on food & beverages on movies",image:{listingImage:`${n.BMSCDN_ASSETS_URL}/static/2022/05/fnb-offer.png`,offerslandingmobileandcardmanagement:`${n.BMSCDN_ASSETS_URL}/static/2022/05/fnb-offer-image.png`,offerslandingpagebottomsheet:`${n.BMSCDN_ASSETS_URL}/static/2022/05/fnb-offer-image.png`},width:"62",height:"108",altText:"food & beverages offer",color:"#AE1E31",tncShort:{terms:["Buy movie tickets on BookMyShow using Play credit card and get INR 100/- off on F&B.","Offer can be availed once every month."]},tncMain:[{heading:"How to avail on mobile app",details:["Go through the regular ticketing flow for selecting the movie/event/concert/play of your choice.","Proceed to payments page","Confirm your details by providing your email id & mobile number as this information will be used for confirming your transaction.","To avail offer, check ‘Unlock Offer or Apply Promocodes’.","Click on the tab - Credit/ Debit/ Net Banking.","Click on ‘Select Offer’ and choose ‘PLAY Credit Card – F&B Offer’ offer from the offers drop down list.","Enter your 16 digit credit card number in the box and click on ‘Check’.","Congratulations! You would have successfully availed your offer.","You will have to pay the remaining transaction amount using the same card through which you have availed the offer. Your card number will auto populate in the box. To make the payment, enter your name on the card, expiry date and CVV card details."]},{heading:"How to avail on website",details:["Go through the regular ticketing flow for selecting the movie/event/concert/play of your choice.","Proceed to payments page","Confirm your details by providing your email id & mobile number as this information will be used for confirming your transaction.","To avail offer, check ‘Unlock Offer or Apply Promocodes’ at the bottom of the review screen.","Click on the tab - Credit/ Debit/ Net Banking.","Click on ‘Select Offer’ and choose ‘PLAY Credit Card – F&B Offer’ from the offers drop down list.","Enter your 16 digit credit card number in the box and click on ‘Check’.","Congratulations! You would have successfully availed your offer.","You will have to pay the remaining transaction amount using the same card through which you have availed the offer. Your card number will auto populate in the box. To make the payment, enter your name on the card, expiry date and CVV card details."]},{heading:"Terms & Conditions:",details:["Maximum discount of INR 100/- on F&B is available under this offer.","This offer is available only if F&B is booked along with movie tickets on BookMyShow.","Offer can be availed once every month and there shall be carry forward if it is unutilised in a particular month.","This offer is applicable on F&B only. Movie ticket price and internet handling charges will have to be paid as levied by the cardholder.To avail offer, check ‘Unlock Offer or Apply Promocodes’ at the bottom of the review screen.","In case you have applied for the discount but the transaction doesn’t go through for some reason, kindly wait for 20 minutes before trying to avail the discount again.","The current purchase process at www.bookmyshow.com will remain unchanged till the stage where the eligible card number is provided. After this stage the website will recognize the eligible card, reduce the bill amount (if eligible) and notify the transacting eligible cardholder accordingly.","This offer is valid only for users coming directly to the BookMyShow website and mobile app not via individual cinema / venue sites.","This offer cannot be combined with any other offer/winpin/discount on BookMyShow.","Tickets once bought online, shall be considered sold and cannot be cancelled, refunded or exchanged.","Once the booking is committed, the confirmation mail/SMS received from BookMyShow needs to be exchanged with the ticket available at the theatre.","Cardholders shall not be entitled to compensation / benefits in any form whatsoever in lieu of the offer being availed.","Bigtree & RBL Bank Limited reserves the right to disqualify any cardholder/s from the benefits of the program. If case of any fraudulent activity, prosecution will be carried according to the purpose of availing the benefits under the program","Bigtree & RBL Bank Limited reserves the right to modify/change all or any of the terms applicable to the program without assigning any reasons or without any prior intimation whatsoever","Bigtree & RBL Bank Limited also reserves the right to discontinue the program without assigning any reasons or without any prior intimation whatsoever.","Individual cinema rules are applicable.","In addition to the above, this offer on the website is also subject to BookMyShow’s general Terms of Use. Kindly refer to BookMyShow’s Terms & Conditions on the homepage","The cardholder shall be required to give personal information and card details online for the tickets purchased on www.bookmyshow.com","In case of any disputes, Bigtree Entertainment’s decision will be final."]}]},{code:2,heading:"Get ₹500 off on movies, events or stream",image:{listingImage:`${n.BMSCDN_ASSETS_URL}/static/2022/05/movie-offer.png`,offerslandingmobileandcardmanagement:`${n.BMSCDN_ASSETS_URL}/static/2022/05/movies-offer-image.png`,offerslandingpagebottomsheet:`${n.BMSCDN_ASSETS_URL}/static/2022/05/movies-offer-image.png`},width:"62",height:"108",altText:"movies, events or stream offer",color:"#000000",tncShort:{terms:["Spend INR 5,000/- or more in a billing cycle on your PLAY credit card and get 2 free tickets on BookMyShow upto INR 500/-","Discount offer can be availed on any category on BookMyShow i.e. movies/plays/sports/activities & STREAM.","This offer will be available every month subject to the spend amount criteria mentioned.","Qualifying purchase value for the monthly benefit shall exclude all transactions made on fuel, rent, wallet,insurance, utilities, and government services categories w.e.f. 9th October 2023."]},tncMain:[{heading:"How to avail on mobile app",details:["Go through the regular ticketing flow for selecting the movie/event/concert/play of your choice.","Proceed to payments page","Confirm your details by providing your email id & mobile number as this information will be used for confirming your transaction.","To avail offer, check ‘Unlock Offer or Apply Promocodes’.","Click on the tab - Credit/ Debit/ Net Banking.","Click on ‘Select Offer’ and choose ‘PLAY Credit Card – F&B Offer’ offer from the offers drop down list.","Enter your 16 digit credit card number in the box and click on ‘Check’.","Congratulations! You would have successfully availed your offer.","You will have to pay the remaining transaction amount using the same card through which you have availed the offer. Your card number will auto populate in the box. To make the payment, enter your name on the card, expiry date and CVV card details."]},{heading:"How to avail on website",details:["Go through the regular ticketing flow for selecting the movie/event/concert/play of your choice.","Proceed to payments page","Confirm your details by providing your email id & mobile number as this information will be used for confirming your transaction.","To avail offer, check ‘Unlock Offer or Apply Promocodes’ at the bottom of the review screen.","Click on the tab - Credit/ Debit/ Net Banking.","Click on ‘Select Offer’ and choose ‘PLAY Credit Card – F&B Offer’ from the offers drop down list.","Enter your 16 digit credit card number in the box and click on ‘Check’.","Congratulations! You would have successfully availed your offer.","You will have to pay the remaining transaction amount using the same card through which you have availed the offer. Your card number will auto populate in the box. To make the payment, enter your name on the card, expiry date and CVV card details."]},{heading:"Terms & Conditions:",details:["2 free tickets up to a maximum discount of INR 500/- is available under this offer.","Offer can be availed on any category on BookMyShow. ","If the offer is availed on movies, then minimum 2 tickets will have to be booked to avail the offer and the maximum discount will be INR 250/- on each ticket.","Offer will be available for a period of 30 days from the end of the billing cycle in which spend criteria of INR 5000/- has been fulfilled.","In case you have applied for the discount but the transaction doesn’t go through for some reason, kindly wait for 20 minutes before trying to avail the discount again.","The current purchase process at www.bookmyshow.com will remain unchanged till the stage where the eligible card number is provided. After this stage the website will recognize the eligible card, reduce the bill amount (if eligible) and notify the transacting eligible cardholder accordingly.","This offer is valid only for users coming directly to the BookMyShow website and mobile app not via individual cinema / venue sites.","This offer cannot be combined with any other offer/winpin/discount on BookMyShow.","Tickets once bought online, shall be considered sold and cannot be cancelled, refunded or exchanged.","Once the booking is committed, the confirmation mail/SMS received from BookMyShow needs to be exchanged with the ticket available at the theatre.","Cardholders shall not be entitled to compensation / benefits in any form whatsoever in lieu of the offer being availed.","Bigtree & RBL Bank Limited reserves the right to disqualify any cardholder/s from the benefits of the program. If case of any fraudulent activity, prosecution will be carried according to the purpose of availing the benefits under the program","Bigtree & RBL Bank Limited reserves the right to modify/change all or any of the terms applicable to the program without assigning any reasons or without any prior intimation whatsoever","Bigtree & RBL Bank Limited also reserves the right to discontinue the program without assigning any reasons or without any prior intimation whatsoever.","Individual cinema rules are applicable.","In addition to the above, this offer on the website is also subject to BookMyShow’s general Terms of Use. Kindly refer to BookMyShow’s Terms & Conditions on the homepage","The cardholder shall be required to give personal information and card details online for the tickets purchased on www.bookmyshow.com","In case of any disputes, Bigtree Entertainment’s decision will be final.","The offer is not applicable for BMS Stream iOS device, iOS users can avail the code on BMS Andriod or BMS web.","This offer can be availed on minimum transaction amount of ₹1 using your card."]}]}]},corporateOffer:{headline:"Grab these coupons before they go away",subHeadline:"Discover offers and discounts on your favourite brands"}},Da="inCompleteApplicationWithoutCreditLimit",Na="inCompleteApplicationWithCreditLimit",ja="applicationSubmittedKycPending",Pa="applicationSubmittedKycCompleted",Ma="inActiveCard",Ba="inActiveUkycCard",Ua="activeCard",Fa="approved",Ga="success",Ha={INCOMPLETE_APPLICATION_WITHOUT_CREDIT_LIMIT:"in_progress",INCOMPLETE_APPLICATION_WITH_CREDIT_LIMIT:"in_progress",APPLICATION_SUBMITTED_KYC_PENDING:"kyc_scheduled",INACTIVE_CARD:"kyc_approved",ACTIVE_CARD:"card_active",INACTIVE_UKYC_CARD:"inActiveUkycCard"},Ya="https://pgi.billdesk.com/pgidsk/pgmerc/rtncard/index.jsp",Va="Your Play card will be dispatched soon",Wa="Delivery address",Ka="For any queries call RBL bank helpline at ",$a="022 6232 7777",Qa=" or email at ",qa="cardservices@rblbank.com",za=`${n.BMSCDN_ASSETS_URL}/static/2022/05/lock-gift.png`,Xa="Activate your card and unlock rewards worth ₹10,000",Za="Learn how to activate your Play card",Ja={welcomeAbroadImageURL:`${n.BMSCDN_ASSETS_URL}/static/2022/05/welcome-abroad.png`,welcomeAbroadImageWidth:"80",welcomeAbroadImageHeight:"60",welcomeAbroadText:"Welcome aboard!",welcomeAbroadSubText:"You have won, ₹200 BookMyShow cash"},er={howToActivate:{howToActivateHeadline:"How to Activate your Play card",howToActivateData:[{id:1,value:"To activate your Play Credit Card, set your credit card PIN in RBL Bank MyCard App and Unbox the world of entertainment, rewards & more"}]}},tr=[{id:1,headline:"How to view Play card statement",data:[{id:1,value:"You can easily access your statement by using RBL digital channels Chatbot, MyCard Application, WhatsApp banking. Below is the process to be followed for the same."}]},{id:2,headline:"Mycard App",data:[{id:1,value:"Login on Mycard app with MPIN"},{id:2,value:"Click on view statement tab on landing page"},{id:3,value:"Click on Past statement tab on bottom of page"},{id:4,value:"Select statement month and click on download and to email to register email id click on Email option"},{id:5,value:"Credit card statement will be available in PDF format"},{id:6,value:"Open statement with password - First four alphabet of name printed on card and DOB in DDMMYY format"}]},{id:3,headline:"RBLCares Chatbot",data:[{id:1,value:"Please visit website - www.rblbank.com"},{id:2,value:"Click on RBLCares tab on bottom of page"},{id:3,value:"Select Balance and Statement option"},{id:4,value:"Click on download your credit card statement"},{id:5,value:"There will be prompt to login"},{id:6,value:"Login with card # + registered mobile # + OTP or Mycard app credentials"},{id:7,value:"Select card #  and month for which statement is required"},{id:8,value:"Credit card statement will be available in PDF format"},{id:9,value:"Open statement with password - First four alphabet of name printed on card and DOB in DDMMYY format "}]},{id:4,headline:"Whatsapp",data:[{id:1,value:'Please send message "Hi" to whatsapp # 8433598888'},{id:2,value:"List of service option will be displayed"},{id:3,value:'Type "4" for Credit Card statement'},{id:4,value:"Type number for which card statement is required"},{id:5,value:"Type number for which month statement is required"},{id:6,value:"Credit card statement will be available in PDF format"},{id:7,value:"Open statement with password - First four alphabet of name printed on card and DOB in DDMMYY format"}]},{id:5,headline:"For any other queries",data:[{id:1,value:"Kindly write to cardservices@rblbank.com for RBL Bank Card to know the status of your credit card."},{id:2,value:"You can also reach out to RBL credit card helpline at 022 6232 7777 or  write email at cardservices@rblbank.com to know the status of your card account."}]}],or=[{id:1,headline:"Customer Support",data:[{id:1,value:"Kindly write to cardservices@rblbank.com for RBL Bank Card to know the status of your credit card."},{id:2,value:"You can also reach out to RBL credit card helpline at 022 6232 7777 or  write email at cardservices@rblbank.com to know the status of your card account."}]}],sr={faqHeadline:"Manage my card",faqs:[{id:1,faqText:"How can I apply for the Play Card?",faqSubText:"There are numerous ways to apply for the Play Card. Click on Apply Now or head over to the Profile section and click on Apply."},{id:2,faqText:"What is BMS Cash/Voucher? Where can I use/spend it?",faqSubText:"BMS Cash/Voucher or BookMyShow Cash/Voucher is virtual currency. After your application has been approved, 200 BMS Cash will be credited to your account directly, which can be used for your next purchase on BookMyShow. (BMS Cash will be stopped from 28.04.2026, and a BMS Voucher will be credited to the customer once VKYC is completed and the card is onboarded within 30 days to register email id.)"},{id:3,faqText:"What are the joining charges for the Play card? And what’s the annual renewal fees?",faqSubText:`The card is free for SuperStar (ss) users and there is a joining fee of ${n.CURRENCY_CONST}500 for non SS. Annual renewal fees will also be waived for superstar users.`},{id:4,faqText:"How do I become a Superstar member?",faqSubText:"Complete 10 transactions in a calendar year, and you become a Superstar member!"},{id:5,faqText:"Where can I use the Play Card?",faqSubText:"Your Play Card can be used across websites and apps, as well as on offline POS machines."},{id:6,faqText:"Can I share my Play Card benefits with others?",faqSubText:"Every member is unique, which is why your Play Card benefits cannot be transferred or shared with another."},{id:7,faqText:"Can one or more benefits be clubbed together in a transaction?",faqSubText:"Unfortunately, your BMS Cash cannot be clubbed with another offer. However, when booking cinema tickets, a Food & Beverage discount can be applied during a purchase of 2+ tickets."}]},nr={cardActivatedOfferHeadline:"Save effortlessly with Play -Every month!",cardActivatedOfferSubHeadline:"Spend ₹5000 or more in a month & get ₹500 off on BookMyShow",cardActivatedOfferImage:`${n.BMSCDN_ASSETS_URL}/static/2022/05/card-activate-offer.png`,cardActivatedOfferImageWidth:"66",cardActivatedOfferImageHeight:"84"},ir=`${n.BMSCDN_ASSETS_URL}/static/2022/05/copy-to-clipboard.png`,ar={headerText:"Reward Details",useCodeText:"Use Code:",offerCodeID:"offerCode",aboutRewardHeadline:"About Rewards",snackBarType:"toast",snackBarText:"Copied to clipboard successfully",snackBarInterval:"2000",availNowCtaText:"Avail now",moreDetailsText:"More Details",applyNowCtaText:"APPLY FOR PLAY CARD"},rr={offerLockImage:`${n.BMSCDN_ASSETS_URL}/static/2022/05/offer-lock.png`,offerLockWidth:"36",offerLockHeight:"36",activateOfferText:"Activate your card to redeem offer",activateOfferCtaText:"How to Activate Play card"},cr={mobileBanner:`${n.BMSCDN_ASSETS_URL}/static/2022/06/offer-banner-mobile.png`,desktopBanner:`${n.BMSCDN_ASSETS_URL}/static/2022/05/desktop-offer-banner.png`,bannerAltText:"Play Credit Card Offers",offerInfoSection:{validOnText:"VALID ON",validOnValue:"Web & App",applicationFeeText:"APPLICATION FEE",applicationFeeValue:"₹500",applyCardCtaText:"APPLY FOR PLAY CARD"},welcomeOffer:{headline:"We welcome you with swag!",subHeadline:"Start your Play journey with some exciting offers",welcomeOffers:[{code:1,heading:"Get ₹200 BMS cash on completing journey via VKYC",image:{listingImage:`${n.BMSCDN_ASSETS_URL}/static/2022/06/bms-cash.png`,offerslandingmobileandcardmanagement:`${n.BMSCDN_ASSETS_URL}/static/2022/05/bms-cash-offer-desktop.png`,offerslandingpagebottomsheet:`${n.BMSCDN_ASSETS_URL}/static/2022/06/welcome-offer-bottomsheet.png`,offerslandingpagedesktop:`${n.BMSCDN_ASSETS_URL}/static/2022/05/bms-cash-offer-desktop.png`},width:"62",height:"108",altText:"food & beverages offer",color:"#EB4E62",tncShort:{terms:["BMS Cash of INR 200/- will be rewarded to users successfully completing their Play credit card application.","BMS Cash credited can be adjusted by users against ticket costs for booking on BookMyShow."]},tncMain:[{heading:"Terms & Conditions:",details:["BMS Cash will be valid for a period of 1 year","Upon expiry of validity, BMS Cash cannot be used and there shall be no extension or carry forward allowed.","BMS Cash can be adjusted against ticket costs on BookMyShow only. Convenience fees / internet handling fees / any other levies on the transaction will have to be paid by the user at actuals as charged.","BMS Cash cannot be exchanged in lieu of cash or any other monetary or non-monetary benefit.","Cashback will be credited as BMS Cash to the BookMyShow account of the user within 48 hours of successful completion of Play card application.","Users can redeem BMS Cash against transactions on BookMyShow only and not at individual cinema / event venue websites or applications.","BMS Cash cannot be combined with any other promo code offers available on BookMyShow.","In case of any assistance or queries regarding BMS Cash, BookMyShow support team shall provide assistance.","RBL Bank & BookMyShow shall have the discretion to discontinue / modify / amend this program without assigning any reasons whatsoever.","BookMyShow’s general terms of use apply to this offer. Kindly check BookMyShow’s Terms & Conditions on www.bookmyshow.com"]}]},{code:2,heading:"Get instant ₹500 on activating your Play card",image:{listingImage:`${n.BMSCDN_ASSETS_URL}/static/2022/06/activating-play-card.png`,offerslandingmobileandcardmanagement:`${n.BMSCDN_ASSETS_URL}/static/2022/05/activation-offer-desktop.png`,offerslandingpagebottomsheet:`${n.BMSCDN_ASSETS_URL}/static/2022/06/welcome-offer-bottomsheet.png`,offerslandingpagedesktop:`${n.BMSCDN_ASSETS_URL}/static/2022/05/activation-offer-desktop.png`},width:"51",height:"108",altText:"movies, events or stream offer",color:"#FFD564",isFontColorBlack:!0,tncShort:{terms:["Transact once using your Play credit card within 30 days of card issuance and get INR 500 discount offer on tickets on BookMyShow.","Discount offer can be availed on any category on BookMyShow i.e. movies / plays / sports / activities / STREAM."]},tncMain:[{heading:"How to avail on mobile app",details:["Go through the regular ticketing flow for selecting the movie/event/concert/play of your choice.","Proceed to payments page","Confirm your details by providing your email id & mobile number as this information will be used for confirming your transaction.","To avail offer, check ‘Unlock Offer or Apply Promocodes’.","Click on the tab - Credit/ Debit/ Net Banking.","Click on ‘Select Offer’ and choose ‘PLAY Credit Card – F&B Offer’ offer from the offers drop down list.","Enter your 16 digit credit card number in the box and click on ‘Check’.","Congratulations! You would have successfully availed your offer.","You will have to pay the remaining transaction amount using the same card through which you have availed the offer. Your card number will auto populate in the box. To make the payment, enter your name on the card, expiry date and CVV card details."]},{heading:"How to avail on website",details:["Go through the regular ticketing flow for selecting the movie/event/concert/play of your choice.","Proceed to payments page","Confirm your details by providing your email id & mobile number as this information will be used for confirming your transaction.","To avail offer, check ‘Unlock Offer or Apply Promocodes’ at the bottom of the review screen.","Click on the tab - Credit/ Debit/ Net Banking.","Click on ‘Select Offer’ and choose ‘PLAY Credit Card – F&B Offer’ from the offers drop down list.","Enter your 16 digit credit card number in the box and click on ‘Check’.","Congratulations! You would have successfully availed your offer.","You will have to pay the remaining transaction amount using the same card through which you have availed the offer. Your card number will auto populate in the box. To make the payment, enter your name on the card, expiry date and CVV card details."]},{heading:"Terms & Conditions:",details:["2 free tickets up to a maximum discount of INR 500/- is available under this offer.","Offer can be availed on any category on BookMyShow. ","If the offer is availed on movies, then minimum 2 tickets will have to be booked to avail the offer and the maximum discount will be INR 250/- on each ticket.","The Card member will become eligible for the welcome benefit on making first transaction with the Play Credit Card within 30 days of card issuance. Upon making such transaction the welcome benefit can be availed within 90 days of Card issuance.","In case you have applied for the discount but the transaction doesn’t go through for some reason, kindly wait for 20 minutes before trying to avail the discount again.","The current purchase process at www.bookmyshow.com will remain unchanged till the stage where the eligible card number is provided. After this stage the website will recognize the eligible card, reduce the bill amount (if eligible) and notify the transacting eligible cardholder accordingly.","This offer is valid only for users coming directly to the BookMyShow website and mobile app not via individual cinema / venue sites.","This offer cannot be combined with any other offer/winpin/discount on BookMyShow.","Tickets once bought online, shall be considered sold and cannot be cancelled, refunded or exchanged.","Once the booking is committed, the confirmation mail/SMS received from BookMyShow needs to be exchanged with the ticket available at the theatre.","Cardholders shall not be entitled to compensation / benefits in any form whatsoever in lieu of the offer being availed.","Bigtree & RBL Bank Limited reserves the right to disqualify any cardholder/s from the benefits of the program. If case of any fraudulent activity, prosecution will be carried according to the purpose of availing the benefits under the program","Bigtree & RBL Bank Limited reserves the right to modify/change all or any of the terms applicable to the program without assigning any reasons or without any prior intimation whatsoever","Bigtree & RBL Bank Limited also reserves the right to discontinue the program without assigning any reasons or without any prior intimation whatsoever.","Individual cinema rules are applicable.","In addition to the above, this offer on the website is also subject to BookMyShow’s general Terms of Use. Kindly refer to BookMyShow’s Terms & Conditions on the homepage","The cardholder shall be required to give personal information and card details online for the tickets purchased on www.bookmyshow.com","In case of any disputes, Bigtree Entertainment’s decision will be final.","The offer is not applicable for BMS Stream iOS device, iOS users can avail the code on BMS Andriod or BMS web","This offer can be availed on minimum transaction amount of ₹1 using your card."]}]}]},monthlyOffer:{headline:"Monthly treats",subHeadline:"Start your Play journey with some exciting offers",monthlyOffers:[{code:1,heading:"Get ₹100 off on food & beverages on movies",image:{listingImage:`${n.BMSCDN_ASSETS_URL}/static/2022/05/fnb-offer.png`,offerslandingmobileandcardmanagement:`${n.BMSCDN_ASSETS_URL}/static/2022/05/fnb-offer-image.png`,offerslandingpagebottomsheet:`${n.BMSCDN_ASSETS_URL}/static/2022/06/fnb-offer-bottomsheet.png`,offerslandingpagedesktop:`${n.BMSCDN_ASSETS_URL}/static/2022/05/fnb-offer-desktop.png`},width:"62",height:"108",altText:"food & beverages offer",color:"#AE1E31",tncShort:{terms:["Buy movie tickets on BookMyShow using Play credit card and get INR 100/- off on F&B.","Offer can be availed once every month."]},tncMain:[{heading:"How to avail on mobile app",details:["Go through the regular ticketing flow for selecting the movie/event/concert/play of your choice.","Proceed to payments page","Confirm your details by providing your email id & mobile number as this information will be used for confirming your transaction.","To avail offer, check ‘Unlock Offer or Apply Promocodes’.","Click on the tab - Credit/ Debit/ Net Banking.","Click on ‘Select Offer’ and choose ‘PLAY Credit Card – F&B Offer’ offer from the offers drop down list.","Enter your 16 digit credit card number in the box and click on ‘Check’.","Congratulations! You would have successfully availed your offer.","You will have to pay the remaining transaction amount using the same card through which you have availed the offer. Your card number will auto populate in the box. To make the payment, enter your name on the card, expiry date and CVV card details."]},{heading:"How to avail on website",details:["Go through the regular ticketing flow for selecting the movie/event/concert/play of your choice.","Proceed to payments page","Confirm your details by providing your email id & mobile number as this information will be used for confirming your transaction.","To avail offer, check ‘Unlock Offer or Apply Promocodes’ at the bottom of the review screen.","Click on the tab - Credit/ Debit/ Net Banking.","Click on ‘Select Offer’ and choose ‘PLAY Credit Card – F&B Offer’ from the offers drop down list.","Enter your 16 digit credit card number in the box and click on ‘Check’.","Congratulations! You would have successfully availed your offer.","You will have to pay the remaining transaction amount using the same card through which you have availed the offer. Your card number will auto populate in the box. To make the payment, enter your name on the card, expiry date and CVV card details."]},{heading:"Terms & Conditions:",details:["Maximum discount of INR 100/- on F&B is available under this offer.","This offer is available only if F&B is booked along with movie tickets on BookMyShow.","Offer can be availed once every month and there shall be carry forward if it is unutilised in a particular month.","This offer is applicable on F&B only. Movie ticket price and internet handling charges will have to be paid as levied by the cardholder.To avail offer, check ‘Unlock Offer or Apply Promocodes’ at the bottom of the review screen.","In case you have applied for the discount but the transaction doesn’t go through for some reason, kindly wait for 20 minutes before trying to avail the discount again.","The current purchase process at www.bookmyshow.com will remain unchanged till the stage where the eligible card number is provided. After this stage the website will recognize the eligible card, reduce the bill amount (if eligible) and notify the transacting eligible cardholder accordingly.","This offer is valid only for users coming directly to the BookMyShow website and mobile app not via individual cinema / venue sites.","This offer cannot be combined with any other offer/winpin/discount on BookMyShow.","Tickets once bought online, shall be considered sold and cannot be cancelled, refunded or exchanged.","Once the booking is committed, the confirmation mail/SMS received from BookMyShow needs to be exchanged with the ticket available at the theatre.","Cardholders shall not be entitled to compensation / benefits in any form whatsoever in lieu of the offer being availed.","Bigtree & RBL Bank Limited reserves the right to disqualify any cardholder/s from the benefits of the program. If case of any fraudulent activity, prosecution will be carried according to the purpose of availing the benefits under the program","Bigtree & RBL Bank Limited reserves the right to modify/change all or any of the terms applicable to the program without assigning any reasons or without any prior intimation whatsoever","Bigtree & RBL Bank Limited also reserves the right to discontinue the program without assigning any reasons or without any prior intimation whatsoever.","Individual cinema rules are applicable.","In addition to the above, this offer on the website is also subject to BookMyShow’s general Terms of Use. Kindly refer to BookMyShow’s Terms & Conditions on the homepage","The cardholder shall be required to give personal information and card details online for the tickets purchased on www.bookmyshow.com","In case of any disputes, Bigtree Entertainment’s decision will be final."]}]},{code:2,heading:"Get ₹500 off on movies, events or stream",image:{listingImage:`${n.BMSCDN_ASSETS_URL}/static/2022/05/movie-offer.png`,offerslandingmobileandcardmanagement:`${n.BMSCDN_ASSETS_URL}/static/2022/05/movies-offer-image.png`,offerslandingpagebottomsheet:`${n.BMSCDN_ASSETS_URL}/static/2022/06/monthly-offer-bottomsheet.png`,offerslandingpagedesktop:`${n.BMSCDN_ASSETS_URL}/static/2022/05/movies-offer-desktop.png`},width:"62",height:"108",altText:"movies, events or stream offer",color:"#000000",tncShort:{terms:["Spend INR 5,000 or more in a billing cycle on your Play credit card and get 2 free tickets on BookMyShow upto INR 500/-","Discount offer can be availed on any category on BookMyShow i.e. movies / plays / sports / activities / STREAM.","This offer will be available every month subject to the spend amount criteria mentioned above."]},tncMain:[{heading:"How to avail on mobile app",details:["Go through the regular ticketing flow for selecting the movie/event/concert/play of your choice.","Proceed to payments page","Confirm your details by providing your email id & mobile number as this information will be used for confirming your transaction.","To avail offer, check ‘Unlock Offer or Apply Promocodes’.","Click on the tab - Credit/ Debit/ Net Banking.","Click on ‘Select Offer’ and choose ‘PLAY Credit Card – F&B Offer’ offer from the offers drop down list.","Enter your 16 digit credit card number in the box and click on ‘Check’.","Congratulations! You would have successfully availed your offer.","You will have to pay the remaining transaction amount using the same card through which you have availed the offer. Your card number will auto populate in the box. To make the payment, enter your name on the card, expiry date and CVV card details."]},{heading:"How to avail on website",details:["Go through the regular ticketing flow for selecting the movie/event/concert/play of your choice.","Proceed to payments page","Confirm your details by providing your email id & mobile number as this information will be used for confirming your transaction.","To avail offer, check ‘Unlock Offer or Apply Promocodes’ at the bottom of the review screen.","Click on the tab - Credit/ Debit/ Net Banking.","Click on ‘Select Offer’ and choose ‘PLAY Credit Card – F&B Offer’ from the offers drop down list.","Enter your 16 digit credit card number in the box and click on ‘Check’.","Congratulations! You would have successfully availed your offer.","You will have to pay the remaining transaction amount using the same card through which you have availed the offer. Your card number will auto populate in the box. To make the payment, enter your name on the card, expiry date and CVV card details."]},{heading:"Terms & Conditions:",details:["2 free tickets up to a maximum discount of INR 500/- is available under this offer.","Offer can be availed on any category on BookMyShow. ","If the offer is availed on movies, then minimum 2 tickets will have to be booked to avail the offer and the maximum discount will be INR 250/- on each ticket.","Offer will be available for a period of 30 days from the end of the billing cycle in which spend criteria of INR 5000/- has been fulfilled.","In case you have applied for the discount but the transaction doesn’t go through for some reason, kindly wait for 20 minutes before trying to avail the discount again.","The current purchase process at www.bookmyshow.com will remain unchanged till the stage where the eligible card number is provided. After this stage the website will recognize the eligible card, reduce the bill amount (if eligible) and notify the transacting eligible cardholder accordingly.","This offer is valid only for users coming directly to the BookMyShow website and mobile app not via individual cinema / venue sites.","This offer cannot be combined with any other offer/winpin/discount on BookMyShow.","Tickets once bought online, shall be considered sold and cannot be cancelled, refunded or exchanged.","Once the booking is committed, the confirmation mail/SMS received from BookMyShow needs to be exchanged with the ticket available at the theatre.","Cardholders shall not be entitled to compensation / benefits in any form whatsoever in lieu of the offer being availed.","Bigtree & RBL Bank Limited reserves the right to disqualify any cardholder/s from the benefits of the program. If case of any fraudulent activity, prosecution will be carried according to the purpose of availing the benefits under the program","Bigtree & RBL Bank Limited reserves the right to modify/change all or any of the terms applicable to the program without assigning any reasons or without any prior intimation whatsoever","Bigtree & RBL Bank Limited also reserves the right to discontinue the program without assigning any reasons or without any prior intimation whatsoever.","Individual cinema rules are applicable.","In addition to the above, this offer on the website is also subject to BookMyShow’s general Terms of Use. Kindly refer to BookMyShow’s Terms & Conditions on the homepage","The cardholder shall be required to give personal information and card details online for the tickets purchased on www.bookmyshow.com","In case of any disputes, Bigtree Entertainment’s decision will be final.","The offer is not applicable for BMS